{
  "manifest_version": 2,
  "name": "Better Tabs",
  "version": "3.0.1",
  "description": "Manage browser tabs and keep site sessions alive",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "alarms",
    "cookies",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["lib.js", "background.js"],
    "persistent": true
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Better Tabs"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "better-tabs@localhost",
      "strict_min_version": "139.0"
    }
  }
}
