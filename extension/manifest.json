{
  "manifest_version": 2,
  "name": "Tab Grouper",
  "version": "2.3.6",
  "description": "Group, sort, and manage browser tabs with GitHub PR integration",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "http://localhost/*",
    "https://api.github.com/*",
    "https://github.com/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Tab Grouper"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "pr-tab-grouper@localhost",
      "strict_min_version": "139.0"
    }
  }
}
